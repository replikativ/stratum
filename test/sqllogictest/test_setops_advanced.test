# test_setops_advanced.test
# Advanced set operations: UNION with ORDER BY, UNION ALL preserves dupes,
# INTERSECT/EXCEPT with WHERE, chained set ops.
# Inspired by PostgreSQL regression/union.sql.

statement ok
CREATE TABLE t1 (a INTEGER, b TEXT)

statement ok
INSERT INTO t1 VALUES (1, 'alpha'), (2, 'beta'), (3, 'gamma')

statement ok
CREATE TABLE t2 (a INTEGER, b TEXT)

statement ok
INSERT INTO t2 VALUES (2, 'beta'), (3, 'gamma'), (4, 'delta')

# ============================================================
# UNION — deduplicates
# ============================================================

query IT rowsort
SELECT a, b FROM t1 UNION SELECT a, b FROM t2
----
1	alpha
2	beta
3	gamma
4	delta

# ============================================================
# UNION ALL — preserves duplicates
# ============================================================

query IT rowsort
SELECT a, b FROM t1 UNION ALL SELECT a, b FROM t2
----
1	alpha
2	beta
2	beta
3	gamma
3	gamma
4	delta

# ============================================================
# INTERSECT — common rows
# ============================================================

query IT rowsort
SELECT a, b FROM t1 INTERSECT SELECT a, b FROM t2
----
2	beta
3	gamma

# ============================================================
# EXCEPT — rows in t1 but not t2
# ============================================================

query IT rowsort
SELECT a, b FROM t1 EXCEPT SELECT a, b FROM t2
----
1	alpha

# ============================================================
# Set ops with WHERE
# ============================================================

query IT rowsort
SELECT a, b FROM t1 WHERE a > 1 UNION SELECT a, b FROM t2 WHERE a < 4
----
2	beta
3	gamma

# ============================================================
# UNION with constant columns
# ============================================================

query II rowsort
SELECT 1 AS src, a FROM t1 UNION ALL SELECT 2 AS src, a FROM t2
----
1	1
1	2
1	3
2	2
2	3
2	4
