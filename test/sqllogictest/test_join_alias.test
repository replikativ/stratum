# test_join_alias.test
# Self-joins, overlapping column names, qualified column resolution.
# Verifies that joins where tables share column names produce correct results.

statement ok
CREATE TABLE emp (id INTEGER, name TEXT, mgr_id INTEGER)

statement ok
INSERT INTO emp VALUES (1, 'Alice', 2), (2, 'Bob', 3), (3, 'Carol', NULL)

# ============================================================
# Self-join — employee with their manager
# ============================================================

query ITT rowsort
SELECT e.id, e.name, m.name FROM emp e INNER JOIN emp m ON e.mgr_id = m.id
----
1	Alice	Bob
2	Bob	Carol

# ============================================================
# Self-join — both id columns should be independently accessible
# ============================================================

query II rowsort
SELECT e.id, m.id FROM emp e INNER JOIN emp m ON e.mgr_id = m.id
----
1	2
2	3

# ============================================================
# Self-join with WHERE on qualified column
# ============================================================

query IT rowsort
SELECT e.id, e.name FROM emp e INNER JOIN emp m ON e.mgr_id = m.id WHERE m.name = 'Bob'
----
1	Alice

# ============================================================
# Self-join with aggregate
# ============================================================

query TI rowsort
SELECT m.name, COUNT(*) FROM emp e INNER JOIN emp m ON e.mgr_id = m.id GROUP BY m.name
----
Bob	1
Carol	1

# ============================================================
# Two tables with overlapping non-key column names
# ============================================================

statement ok
CREATE TABLE dept (id INTEGER, name TEXT)

statement ok
INSERT INTO dept VALUES (10, 'Engineering'), (20, 'Sales')

statement ok
CREATE TABLE staff (id INTEGER, name TEXT, dept_id INTEGER)

statement ok
INSERT INTO staff VALUES (1, 'Alice', 10), (2, 'Bob', 20), (3, 'Carol', 10)

query TTI rowsort
SELECT s.name, d.name, s.dept_id FROM staff s INNER JOIN dept d ON s.dept_id = d.id
----
Alice	Engineering	10
Bob	Sales	20
Carol	Engineering	10

# ============================================================
# Three-table chain join
# ============================================================

statement ok
CREATE TABLE orders (id INTEGER, cust_id INTEGER, amount DOUBLE)

statement ok
INSERT INTO orders VALUES (1, 100, 50.0), (2, 200, 75.0), (3, 100, 25.0)

statement ok
CREATE TABLE customers (id INTEGER, region_id INTEGER, cname TEXT)

statement ok
INSERT INTO customers VALUES (100, 1, 'Acme'), (200, 2, 'Globex')

statement ok
CREATE TABLE regions (id INTEGER, rname TEXT)

statement ok
INSERT INTO regions VALUES (1, 'East'), (2, 'West')

query TTIR rowsort
SELECT r.rname, c.cname, o.id, o.amount FROM orders o INNER JOIN customers c ON o.cust_id = c.id INNER JOIN regions r ON c.region_id = r.id
----
East	Acme	1	50.000000
East	Acme	3	25.000000
West	Globex	2	75.000000

# ============================================================
# LEFT self-join — unmatched rows get NULLs
# ============================================================

query ITT rowsort
SELECT e.id, e.name, m.name FROM emp e LEFT JOIN emp m ON e.mgr_id = m.id
----
1	Alice	Bob
2	Bob	Carol
3	Carol	NULL
