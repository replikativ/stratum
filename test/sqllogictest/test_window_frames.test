# test_window_frames.test
# Window function frame specifications, NTILE, PERCENT_RANK, CUME_DIST,
# running SUM, partition totals, multiple windows.
# Inspired by PostgreSQL regression/window.sql.

statement ok
CREATE TABLE emp (depname TEXT, empno INTEGER, salary INTEGER)

statement ok
INSERT INTO emp VALUES ('develop', 1, 5200), ('develop', 2, 4200), ('develop', 3, 4500), ('sales', 4, 4800), ('sales', 5, 5000), ('personnel', 6, 3500), ('personnel', 7, 3900)

# ============================================================
# NTILE — divide into equal groups
# Per SQL standard, window ORDER BY doesn't determine output order
# ============================================================

query II rowsort
SELECT empno, NTILE(3) OVER (ORDER BY salary) FROM emp
----
1	3
2	1
3	2
4	2
5	3
6	1
7	1

# ============================================================
# PERCENT_RANK
# ============================================================

query IR rowsort
SELECT empno, PERCENT_RANK() OVER (ORDER BY salary) FROM emp
----
1	1.000000
2	0.333333
3	0.500000
4	0.666667
5	0.833333
6	0.000000
7	0.166667

# ============================================================
# CUME_DIST
# ============================================================

query IR rowsort
SELECT empno, CUME_DIST() OVER (ORDER BY salary) FROM emp
----
1	1.000000
2	0.428571
3	0.571429
4	0.714286
5	0.857143
6	0.142857
7	0.285714

# ============================================================
# Running SUM with frame specification
# ============================================================

query IIR rowsort
SELECT empno, salary, SUM(salary) OVER (ORDER BY salary ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) FROM emp
----
1	5200	31100.000000
2	4200	11600.000000
3	4500	16100.000000
4	4800	20900.000000
5	5000	25900.000000
6	3500	3500.000000
7	3900	7400.000000

# ============================================================
# Multiple windows in same query
# SUM(salary) OVER (PARTITION BY depname) = partition total (no ORDER BY)
# ============================================================

query TIIR rowsort
SELECT depname, empno, ROW_NUMBER() OVER (PARTITION BY depname ORDER BY salary), SUM(salary) OVER (PARTITION BY depname) FROM emp
----
develop	1	3	13900.000000
develop	2	1	13900.000000
develop	3	2	13900.000000
personnel	6	1	7400.000000
personnel	7	2	7400.000000
sales	4	1	9800.000000
sales	5	2	9800.000000

# ============================================================
# ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING — reverse running SUM
# ============================================================

query IIR rowsort
SELECT empno, salary, SUM(salary) OVER (ORDER BY salary ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING) FROM emp
----
1	5200	5200.000000
2	4200	23700.000000
3	4500	19500.000000
4	4800	15000.000000
5	5000	10200.000000
6	3500	31100.000000
7	3900	27600.000000

# ============================================================
# ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING — COUNT
# ============================================================

query III rowsort
SELECT empno, salary, COUNT(*) OVER (ORDER BY salary ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING) FROM emp
----
1	5200	1
2	4200	5
3	4500	4
4	4800	3
5	5000	2
6	3500	7
7	3900	6

# ============================================================
# ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING — AVG
# ============================================================

query IIR rowsort
SELECT empno, salary, AVG(salary) OVER (ORDER BY salary ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING) FROM emp
----
1	5200	5200.000000
2	4200	4740.000000
3	4500	4875.000000
4	4800	5000.000000
5	5000	5100.000000
6	3500	4442.857143
7	3900	4600.000000
