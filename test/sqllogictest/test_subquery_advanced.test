# test_subquery_advanced.test
# Advanced subqueries: NOT IN, EXISTS, NOT EXISTS, scalar subquery in FROM,
# CTE with aggregation, multiple CTEs.
# Inspired by PostgreSQL regression/subselect.sql and with.sql.

statement ok
CREATE TABLE t1 (a INTEGER, b TEXT)

statement ok
INSERT INTO t1 VALUES (1, 'x'), (2, 'y'), (3, 'z'), (4, 'w')

statement ok
CREATE TABLE t2 (a INTEGER, c TEXT)

statement ok
INSERT INTO t2 VALUES (2, 'p'), (4, 'q'), (6, 'r')

# ============================================================
# IN subquery
# ============================================================

query IT rowsort
SELECT a, b FROM t1 WHERE a IN (SELECT a FROM t2)
----
2	y
4	w

# ============================================================
# NOT IN subquery
# ============================================================

query IT rowsort
SELECT a, b FROM t1 WHERE a NOT IN (SELECT a FROM t2)
----
1	x
3	z

# ============================================================
# EXISTS subquery — skipped: correlated subqueries require row-by-row
# evaluation, incompatible with vectorized columnar architecture
# ============================================================

# query IT rowsort
# SELECT a, b FROM t1 WHERE EXISTS (SELECT 1 FROM t2 WHERE t2.a = t1.a)

# ============================================================
# NOT EXISTS subquery — skipped: same as EXISTS
# ============================================================

# query IT rowsort
# SELECT a, b FROM t1 WHERE NOT EXISTS (SELECT 1 FROM t2 WHERE t2.a = t1.a)

# ============================================================
# CTE with aggregation
# ============================================================

statement ok
CREATE TABLE sales (region TEXT, amount DOUBLE)

statement ok
INSERT INTO sales VALUES ('east', 100.0), ('east', 200.0), ('west', 300.0), ('west', 400.0), ('east', 50.0)

query TR rowsort
WITH region_totals AS (SELECT region, SUM(amount) AS total FROM sales GROUP BY region) SELECT region, total FROM region_totals
----
east	350.000000
west	700.000000

# ============================================================
# CTE used in WHERE — skipped: CTE reference in subquery not yet supported
# ============================================================

# query TR rowsort
# WITH high_regions AS (SELECT region FROM sales GROUP BY region HAVING SUM(amount) > 500) SELECT region, amount FROM sales WHERE region IN (SELECT region FROM high_regions)

# ============================================================
# Subquery in FROM (derived table)
# ============================================================

query TR rowsort
SELECT sub.region, sub.total FROM (SELECT region, SUM(amount) AS total FROM sales GROUP BY region) AS sub WHERE sub.total > 400
----
west	700.000000
